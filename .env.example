# Optional API keys when you switch the runtime config to api mode.
PROJECT1_BIZINFO_CERT_KEY=
PROJECT1_G2B_API_KEY=

# Safe default override file used by both the fixture starter and the api override.
PROJECT1_KEYWORDS_OVERRIDE_PATH=config/keywords.docker.override.toml

# Runtime path overrides kept inside mounted volumes.
PROJECT1_STORAGE_DATABASE_PATH=data/notices.sqlite3
PROJECT1_EXPORT_OUTPUT_DIR=output

# api override defaults to bizinfo enabled / g2b disabled.
# Uncomment when you want to switch Docker api mode to g2b only.
# PROJECT1_SOURCES_BIZINFO_ENABLED=false
# PROJECT1_SOURCES_G2B_ENABLED=true
